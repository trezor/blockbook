{
  "name": "blockbook-openapi-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "lint:spec": "redocly lint ../../openapi.yaml --config redocly.yaml",
    "generate": "openapi-typescript ../../openapi.yaml -o .generated/blockbook.ts",
    "typecheck": "tsc --noEmit",
    "e2e": "tsx src/e2e.ts"
  },
  "overrides": {
    "fast-uri": "3.1.3",
    "js-yaml": "4.3.0",
    "brace-expansion@2": "2.1.2",
    "brace-expansion@>=3": "5.0.7"
  },
  "devDependencies": {
    "@redocly/cli": "2.11.1",
    "@types/ws": "8.18.1",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "https-proxy-agent": "7.0.6",
    "openapi-typescript": "7.10.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "undici": "6.27.0",
    "ws": "8.21.0",
    "yaml": "2.6.1"
  }
}
