{
  "coin": {
    "name": "Optimism Testnet Legacy Geth",
    "shortcut": "tETH",
    "label": "Optimism Testnet",
    "alias": "optimism_testnet_legacy_geth"
  },
  "ports": {
    "backend_rpc": 18203,
    "backend_http": 18303,
    "backend_p2p": 48403
  },
  "backend": {
    "package_name": "backend-optimism-testnet-legacy-geth",
    "package_revision": "satoshilabs-1",
    "system_user": "optimism",
    "version": "0.5.29",
    "binary_url": "https://github.com/ethereum-optimism/optimism/archive/refs/tags/@eth-optimism/l2geth@0.5.29.tar.gz",
    "verification_type": "sha256",
    "verification_source": "4033ccbdcb1edaeb0ef1131cdd4ae4d2fd9258b306e2b5a99419c827a37c7856",
    "extract_command": "mkdir backend/source && tar -C backend/source --strip 1 -xf",
    "exclude_files": [],
    "exec_command_template": "/bin/sh -c '{{.Env.BackendInstallPath}}/{{.Coin.Alias}}/optimism_testnet_legacy_geth_exec.sh 2>> {{.Env.BackendDataPath}}/{{.Coin.Alias}}/backend/{{.Coin.Alias}}.log'",
    "exec_script": "optimism_testnet_legacy_geth.sh",
    "logrotate_files_template": "{{.Env.BackendDataPath}}/{{.Coin.Alias}}/backend/{{.Coin.Alias}}.log",
    "postinst_script_template": "cd {{.Env.BackendInstallPath}}/{{.Coin.Alias}}/source/l2geth && make geth && mv build/bin/geth {{.Env.BackendInstallPath}}/{{.Coin.Alias}} && rm -rf {{.Env.BackendInstallPath}}/{{.Coin.Alias}}/source",
    "service_type": "simple",
    "service_additional_params_template": "",
    "protect_memory": true,
    "mainnet": false,
    "server_config_file": "",
    "client_config_file": ""
  },
  "meta": {
    "package_maintainer": "IT",
    "package_maintainer_email": "it@satoshilabs.com"
  }
}