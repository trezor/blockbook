{
  "coin": {
    "name": "Optimism Testnet",
    "shortcut": "tETH",
    "label": "Optimism Testnet",
    "alias": "optimism_testnet"
  },
  "ports": {
    "backend_rpc": 18200,
    "backend_p2p": 48400,
    "backend_http": 18300,
    "backend_authrpc": 18400,
    "blockbook_internal": 19200,
    "blockbook_public": 19300
  },
  "ipc": {
    "rpc_url_template": "ws://127.0.0.1:{{.Ports.BackendRPC}}",
    "rpc_timeout": 25
  },
  "backend": {
    "package_name": "backend-optimism-testnet",
    "package_revision": "satoshilabs-1",
    "system_user": "optimism",
    "version": "0.11.2-13ee9ab",
    "binary_url": "https://github.com/ethereum-optimism/op-geth/archive/refs/tags/v1.11.2-13ee9ab.tar.gz",
    "verification_type": "sha256",
    "verification_source": "96f79f822dede72f3f674ff88f7ceb4d219b73c0e286a9b80b5c24009901d222",
    "extract_command": "mkdir backend/source && tar -C backend/source --strip 1 -xf",
    "exclude_files": [],
    "exec_command_template": "/bin/sh -c '{{.Env.BackendInstallPath}}/{{.Coin.Alias}}/optimism_testnet_exec.sh 2>> {{.Env.BackendDataPath}}/{{.Coin.Alias}}/backend/{{.Coin.Alias}}.log'",
    "exec_script": "optimism_testnet.sh",
    "logrotate_files_template": "{{.Env.BackendDataPath}}/{{.Coin.Alias}}/backend/{{.Coin.Alias}}.log",
    "postinst_script_template": "cd {{.Env.BackendInstallPath}}/{{.Coin.Alias}}/source/l2geth && make geth && mv build/bin/geth {{.Env.BackendInstallPath}}/{{.Coin.Alias}} && rm -rf {{.Env.BackendInstallPath}}/{{.Coin.Alias}}/source",
    "service_type": "simple",
    "service_additional_params_template": "",
    "protect_memory": true,
    "mainnet": false,
    "server_config_file": "",
    "client_config_file": ""
  },
  "blockbook": {
    "package_name": "blockbook-optimism-testnet",
    "system_user": "blockbook-optimism",
    "internal_binding_template": ":{{.Ports.BlockbookInternal}}",
    "public_binding_template": ":{{.Ports.BlockbookPublic}}",
    "explorer_url": "",
    "additional_params": "",
    "block_chain": {
      "parse": true,
      "mempool_workers": 8,
      "mempool_sub_workers": 2,
      "block_addresses_to_keep": 3000,
      "additional_params": {
        "mempoolTxTimeoutHours": 12,
        "queryBackendOnMempoolResync": false
      }
    }
  },
  "meta": {
    "package_maintainer": "IT",
    "package_maintainer_email": "it@satoshilabs.com"
  }
}